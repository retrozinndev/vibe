{
  "$schema": "https://www.schemastore.org/package.json",
  "name": "vibe",
  "version": "0.0.1",
  "description": "The craziest music player!",
  "homepage": "https://github.com/retrozinndev/Vibe#readme",
  "bugs": {
    "url": "https://github.com/retrozinndev/Vibe/issues"
  },
  "keywords": [
    "music-player",
    "gtk4",
    "libadwaita",
    "gnim",
    "gnomejs"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/retrozinndev/Vibe.git"
  },
  "pnpm": {
    "ignoredBuiltDependencies": [
      "esbuild"
    ]
  },
  "license": "BSD-3-Clause",
  "author": {
    "name": "João Dias",
    "url": "https://github.com/retrozinndev",
    "email": "joaovodias@gmail.com"
  },
  "type": "module",
  "scripts": {
    "types": "bash scripts/types.sh",
    "dev": "bash scripts/build.sh -d && bash scripts/start.sh",
    "devshell": "bash",
    "build": "bash scripts/build.sh",
    "build:release": "bash scripts/release.sh",
    "start": "bash scripts/start.sh",
    "clean": "bash scripts/clean.sh"
  },
  "devDependencies": {
    "esbuild": "^0.27.7",
    "girgen": "^0.3.16",
    "sass": "^1.100.0"
  },
  "dependencies": {
    "gnim": "^1.9.1",
    "gnim-utils": "github:retrozinndev/gnim-utils",
    "libvibe": "link:libvibe"
  }
}
